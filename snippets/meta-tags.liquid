<!-- Meta Tags Snippet — For SEO -->
{%- if request.page_type == 'index' -%}
  <meta name="description" content="{{ shop.description | default: 'KIC is a 3rd-generation Korean manufacturer of PP strapping bands and HDPE tying tape. B2B wholesale, RFQ-based pricing, ISO 9001 certified. Exporting to 20+ countries since 1973.' }}">
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ shop.name }} — Industrial PP Strapping Manufacturer">
  <meta property="og:description" content="{{ shop.description | default: 'B2B PP strapping manufacturer. ISO 9001 certified. Korean manufacturer since 1973. Exporting worldwide.' }}">
  <meta property="og:url" content="{{ canonical_url }}">
  {%- if settings.share_image -%}
    <meta property="og:image" content="{{ settings.share_image | image_url: width: 1200 }}">
  {%- endif -%}
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ shop.name }} — PP Strapping Manufacturer">
  <meta name="twitter:description" content="{{ shop.description | default: 'B2B PP strapping manufacturer. ISO 9001 certified. Korean manufacturer since 1973.' }}">

{%- elsif request.page_type == 'product' -%}
  <meta name="description" content="{{ product.description | strip_html | truncate: 160 | default: product.title | append: ' — KIC industrial PP strapping. B2B pricing on request. ISO 9001 certified Korean manufacturer.' }}">
  <meta property="og:type" content="product">
  <meta property="og:title" content="{{ product.title }} — {{ shop.name }}">
  <meta property="og:description" content="{{ product.description | strip_html | truncate: 200 }}">
  <meta property="og:url" content="{{ canonical_url }}">
  {%- if product.featured_image -%}
    <meta property="og:image" content="{{ product.featured_image | image_url: width: 1200 }}">
  {%- endif -%}

{%- elsif request.page_type == 'collection' -%}
  <meta name="description" content="{{ collection.description | strip_html | truncate: 160 | default: 'KIC PP strapping collection — ' | append: collection.title | append: '. B2B wholesale, RFQ pricing. ISO 9001 certified manufacturer.' }}">
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ collection.title }} — {{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">

{%- elsif request.page_type == 'article' -%}
  <meta name="description" content="{{ article.excerpt | strip_html | truncate: 160 | default: article.title }}">
  <meta property="og:type" content="article">
  <meta property="og:title" content="{{ article.title }} — {{ shop.name }}">
  <meta property="og:description" content="{{ article.excerpt | strip_html | truncate: 200 }}">
  <meta property="og:url" content="{{ canonical_url }}">
  {%- if article.image -%}
    <meta property="og:image" content="{{ article.image | image_url: width: 1200 }}">
  {%- endif -%}

{%- else -%}
  <meta name="description" content="{{ page_description | default: shop.description }}">
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ page_title }} — {{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
{%- endif -%}

<!-- Canonical -->
<link rel="canonical" href="{{ canonical_url }}">

<!-- Structured Data: Organization -->
{%- if request.page_type == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "KIC — Korea Industrial Company",
  "url": "{{ shop.url }}",
  "logo": "{{ shop.url }}/cdn/shop/files/kic-logo.png",
  "description": "3rd generation Korean manufacturer of PP strapping and HDPE tying tape. Est. 1973. ISO 9001:2015 certified. Exporting to 20+ countries.",
  "foundingDate": "1973",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "15, Hwanggeum-ro 273beon-gil, Yangchon-eup",
    "addressLocality": "Gimpo-si",
    "addressRegion": "Gyeonggi-do",
    "postalCode": "10050",
    "addressCountry": "KR"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+82-31-998-1740",
    "contactType": "sales",
    "email": "sales@powerband.co.kr",
    "availableLanguage": ["English", "Korean"]
  },
  "sameAs": [
    "https://8straps.com",
    "https://powerband.co.kr"
  ]
}
</script>
{%- endif -%}

{%- if request.page_type == 'product' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{ product.title | escape }}",
  "description": "{{ product.description | strip_html | truncate: 500 | escape }}",
  "brand": {
    "@type": "Brand",
    "name": "KIC"
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "Korea Industrial Company (KIC)"
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "USD",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "description": "Price available on request (RFQ). B2B wholesale only."
    },
    "seller": {
      "@type": "Organization",
      "name": "KIC"
    },
    "availability": "https://schema.org/InStock"
  }
}
</script>
{%- endif -%}
