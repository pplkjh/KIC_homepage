<!-- RFQ Modal — Global Modal (rendered in layout/theme.liquid via render tag) -->
<div class="kic-modal-overlay" id="kic-rfq-overlay" role="dialog" aria-modal="true" aria-labelledby="kic-rfq-modal-title">
  <div class="kic-modal" id="kic-rfq-modal">
    <div class="kic-modal__header">
      <h2 id="kic-rfq-modal-title">
        <i class="fas fa-file-invoice"></i>
        Request a Quote (RFQ)
      </h2>
      <button class="kic-modal__close" id="kic-rfq-modal-close" aria-label="Close">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="kic-modal__body">
      <div class="kic-rfq-product-hint" id="rfq-modal-product-hint" style="display: none;">
        <i class="fas fa-box"></i>
        <span></span>
      </div>

      {%- form 'contact', id: 'rfq-modal-form' -%}
        {%- if form.posted_successfully? -%}
          <div class="kic-rfq-form__success">
            <i class="fas fa-check-circle"></i>
            <h4>Quote Request Sent!</h4>
            <p>Thank you! Our sales team will contact you within 24 business hours with a personalized quote. You'll receive a confirmation at your email address.</p>
          </div>
        {%- else -%}
          <div class="kic-rfq-form__grid">
            <div class="kic-rfq-form__field">
              <label for="rfq-modal-name">Full Name <span class="required">*</span></label>
              <input type="text" id="rfq-modal-name" name="contact[name]" placeholder="John Smith" required autocomplete="name">
            </div>
            <div class="kic-rfq-form__field">
              <label for="rfq-modal-company">Company Name <span class="required">*</span></label>
              <input type="text" id="rfq-modal-company" name="contact[company]" placeholder="ABC Industrial Ltd." required>
            </div>
            <div class="kic-rfq-form__field">
              <label for="rfq-modal-email">Business Email <span class="required">*</span></label>
              <input type="email" id="rfq-modal-email" name="contact[email]" placeholder="you@company.com" required autocomplete="email">
            </div>
            <div class="kic-rfq-form__field">
              <label for="rfq-modal-phone">Phone / WhatsApp</label>
              <input type="tel" id="rfq-modal-phone" name="contact[phone]" placeholder="+1 555 000 0000" autocomplete="tel">
            </div>
            <div class="kic-rfq-form__field">
              <label for="rfq-modal-country">Country <span class="required">*</span></label>
              <select id="rfq-modal-country" name="contact[country]" required>
                <option value="">Select Country</option>
                <option>United States</option>
                <option>United Kingdom</option>
                <option>Germany</option>
                <option>France</option>
                <option>Australia</option>
                <option>Canada</option>
                <option>Japan</option>
                <option>China</option>
                <option>South Korea</option>
                <option>India</option>
                <option>Brazil</option>
                <option>Mexico</option>
                <option>Netherlands</option>
                <option>Italy</option>
                <option>Spain</option>
                <option>Poland</option>
                <option>Other</option>
              </select>
            </div>
            <div class="kic-rfq-form__field">
              <label for="rfq-modal-product">Product of Interest <span class="required">*</span></label>
              <select id="rfq-modal-product" name="contact[product_interest]" required>
                <option value="">Select Product</option>
                <option>PP Strap — Fully Auto Machine Grade</option>
                <option>PP Strap — Semi Auto Machine Grade</option>
                <option>PP Strap — Hand Grade / Manual</option>
                <option>PP Strap — High Tension Grade</option>
                <option>PP Strap — Custom Printed / OEM</option>
                <option>PE / HDPE Tying Tape</option>
                <option>Buckles &amp; Seals</option>
                <option>Tensioners &amp; Tools</option>
                <option>Multiple Products / Full Catalog</option>
              </select>
            </div>
            <div class="kic-rfq-form__field kic-rfq-form__field--full">
              <label for="rfq-modal-quantity">Estimated Quantity / Order Volume</label>
              <input type="text" id="rfq-modal-quantity" name="contact[quantity]" placeholder="e.g. 500 rolls per month, 10 pallets per order">
            </div>
            <div class="kic-rfq-form__field kic-rfq-form__field--full">
              <label for="rfq-modal-message">Additional Requirements / Message</label>
              <textarea id="rfq-modal-message" name="contact[body]" rows="3" placeholder="Width, thickness, color, certifications required, delivery timeline, destination port, etc."></textarea>
            </div>
          </div>

          <div class="kic-rfq-form__consent">
            <label class="kic-rfq-form__checkbox">
              <input type="checkbox" name="contact[consent]" required>
              <span>I agree to be contacted by KIC regarding my quote request. B2B wholesale only.</span>
            </label>
          </div>

          <button type="submit" class="btn btn--primary btn--lg btn--block kic-rfq-form__submit">
            <i class="fas fa-paper-plane"></i>
            Submit Quote Request
          </button>
          <p class="kic-rfq-form__note">
            <i class="fas fa-lock"></i>
            Your information is strictly confidential. Response within 24 business hours.
          </p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</div>
