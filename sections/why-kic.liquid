<!-- KIC Why Choose Us / Value Proposition Section -->
<section class="kic-values section-{{ section.id }}"
  style="background: {{ section.settings.bg_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="kic-section-header kic-section-header--center">
      {%- if section.settings.tagline != blank -%}
        <span class="kic-section-tagline">{{ section.settings.tagline }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="kic-section-title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="kic-section-subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="kic-values__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'value' -%}
          <div class="kic-value-card" {{ block.shopify_attributes }}>
            <div class="kic-value-card__icon-wrap">
              <i class="{{ block.settings.icon }}"></i>
            </div>
            <h3 class="kic-value-card__title">{{ block.settings.title }}</h3>
            <p class="kic-value-card__desc">{{ block.settings.description }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="kic-values__cta">
        <a href="{{ section.settings.cta_url }}" class="btn btn--primary btn--lg">
          {{ section.settings.cta_label }}
          <i class="fas fa-arrow-right"></i>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Why KIC / Values",
  "tag": "section",
  "class": "kic-section-values",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f5f7fa"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Why KIC"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The KIC Advantage"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "What sets KIC apart from other strapping suppliers? Here's why thousands of global buyers trust us."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Request a Free Sample"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 80,
      "unit": "px",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 80,
      "unit": "px",
      "label": "Padding bottom"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value Card",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Font Awesome icon class",
          "default": "fas fa-medal"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Superior Breaking Strength"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Higher breaking strength among similar straps — engineered with Korean virgin resin for consistent performance."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why KIC / Values",
      "category": "KIC Sections",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "icon": "fas fa-dumbbell",
            "title": "Superior Breaking Strength",
            "description": "Higher breaking strength among similar straps — engineered with Korean virgin resin for consistent, reliable performance under load."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "fas fa-certificate",
            "title": "ISO 9001:2015 Certified",
            "description": "Our quality management system is internationally certified, ensuring every roll meets strict specifications from start to finish."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "fas fa-ruler-combined",
            "title": "Consistent Specification",
            "description": "Consistent width, thickness, and breaking strength from the first meter to the last. No camber. No surprises."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "fas fa-palette",
            "title": "Custom Color & Print OEM",
            "description": "Vivid and unique colored straps with RoHS-certified materials. Custom printed straps with OEM shipping marks available."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "fas fa-leaf",
            "title": "Eco-Friendly Materials",
            "description": "We use Korean virgin resin that leaves fewer residues in your machines and causes less environmental impact."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "fas fa-globe-asia",
            "title": "20+ Countries Export Experience",
            "description": "Decades of exporting expertise means we understand customs, logistics, and compliance for your destination market."
          }
        }
      ]
    }
  ]
}
{% endschema %}
