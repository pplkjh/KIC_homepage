{%- style -%}
  .footer {
    background: white;
    border-top: 1px solid #e5e5e5;
    padding: 2rem;
  }

  .footer-container {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    md-flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer-text {
    font-family: 'Noto Sans KR', sans-serif;
    font-size: 0.875rem;
    color: #4b5563;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .footer-link {
    font-family: 'Noto Sans KR', sans-serif;
    font-size: 0.875rem;
    color: #4b5563;
    text-decoration: none;
    transition: color 0.2s ease;
    cursor: pointer;
    background: none;
    border: none;
  }

  .footer-link:hover {
    color: #2D8659;
  }

  @media (max-width: 768px) {
    .footer-container {
      flex-direction: column;
      text-align: center;
    }

    .footer-links {
      justify-content: center;
    }
  }
{%- endstyle -%}

<footer class="footer">
  <div class="footer-container">
    <div class="footer-text">
      © 2024 ECO TECH Co., Ltd. All rights reserved.
    </div>
    <div class="footer-links">
      <button class="footer-link" onclick="document.querySelector('#home').scrollIntoView({behavior: 'smooth'})">
        맨 위로
      </button>
    </div>
  </div>
</footer>
