<!-- KIC About / Company Introduction Section -->
<section class="kic-about section-{{ section.id }}" id="about-kic"
  style="background: {{ section.settings.bg_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="kic-about__inner {% if section.settings.image_position == 'right' %}kic-about__inner--reversed{% endif %}">

      <!-- Image Column -->
      <div class="kic-about__media">
        {%- if section.settings.about_image != blank -%}
          <div class="kic-about__image-wrap">
            <img src="{{ section.settings.about_image | image_url: width: 700 }}"
                 alt="{{ section.settings.heading | escape }}"
                 class="kic-about__image"
                 loading="lazy"
                 width="700">
            {%- if section.settings.badge_text != blank -%}
              <div class="kic-about__badge">
                <span class="kic-about__badge-number">{{ section.settings.badge_number }}</span>
                <span class="kic-about__badge-text">{{ section.settings.badge_text }}</span>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.about_image_2 != blank -%}
          <div class="kic-about__image-secondary-wrap">
            <img src="{{ section.settings.about_image_2 | image_url: width: 350 }}"
                 alt="KIC Manufacturing"
                 class="kic-about__image-secondary"
                 loading="lazy"
                 width="350">
          </div>
        {%- endif -%}
      </div>

      <!-- Text Column -->
      <div class="kic-about__content">
        {%- if section.settings.tagline != blank -%}
          <span class="kic-section-tagline">{{ section.settings.tagline }}</span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="kic-section-title">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="kic-about__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}

        {%- if section.settings.body_text != blank -%}
          <div class="kic-about__body">{{ section.settings.body_text }}</div>
        {%- endif -%}

        <!-- Key Points -->
        {%- if section.blocks.size > 0 -%}
          <ul class="kic-about__points">
            {%- for block in section.blocks -%}
              {%- if block.type == 'point' -%}
                <li class="kic-about__point" {{ block.shopify_attributes }}>
                  <i class="fas fa-check-circle"></i>
                  <span>{{ block.settings.text }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        <div class="kic-about__actions">
          {%- if section.settings.cta_label != blank -%}
            <a href="{{ section.settings.cta_url }}" class="btn btn--primary">
              {{ section.settings.cta_label }}
              <i class="fas fa-arrow-right"></i>
            </a>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "About / Company Intro",
  "tag": "section",
  "class": "kic-section-about",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "image_picker",
      "id": "about_image",
      "label": "Primary image"
    },
    {
      "type": "image_picker",
      "id": "about_image_2",
      "label": "Secondary floating image"
    },
    {
      "type": "text",
      "id": "badge_number",
      "label": "Badge number",
      "default": "1973"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Est."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Section tagline",
      "default": "About KIC"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "3rd Generation Korean PP Strapping Manufacturer"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Since 1973, KIC has been at the forefront of industrial packaging solutions — crafting world-class PP strapping and HDPE tying tape for demanding global markets."
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>KIC (Korea Industrial Company) is a family-owned manufacturer based in Gimpo, Korea. Founded in 1973 and now operated by its third generation, we bring over 50 years of expertise to every roll of strapping we produce.</p><p>We export to 20+ countries worldwide, serving clients in logistics, agriculture, steel, paper, textile, and wood industries. Our ISO 9001:2015-certified facility ensures consistent quality across every batch.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Learn More About KIC"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 80,
      "unit": "px",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 80,
      "unit": "px",
      "label": "Padding bottom"
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Key Point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Point text",
          "default": "ISO 9001:2015 certified quality management"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About / Company Intro",
      "category": "KIC Sections",
      "blocks": [
        {
          "type": "point",
          "settings": {
            "text": "ISO 9001:2015 certified quality management system"
          }
        },
        {
          "type": "point",
          "settings": {
            "text": "Over 50 years of PP strapping manufacturing expertise"
          }
        },
        {
          "type": "point",
          "settings": {
            "text": "Exporting to 20+ countries across 5 continents"
          }
        },
        {
          "type": "point",
          "settings": {
            "text": "RoHS-compliant, eco-friendly raw materials"
          }
        },
        {
          "type": "point",
          "settings": {
            "text": "Custom OEM/ODM manufacturing available"
          }
        }
      ]
    }
  ]
}
{% endschema %}
