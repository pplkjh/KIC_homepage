<section class="hero" id="hero">
  <div class="hero-bg">
    {%- if section.settings.bg_image != blank -%}
      {{ section.settings.bg_image | image_tag: class: 'hero-bg-img', loading: 'eager', fetchpriority: 'high' }}
    {%- else -%}
      <div class="hero-bg-fallback"></div>
    {%- endif -%}
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content">
    {%- if section.settings.logo != blank -%}
      <div class="hero-logo-wrap animate-fade-up" style="animation-delay:0.1s">
        {{ section.settings.logo | image_tag: class: 'hero-logo', width: 180, loading: 'eager' }}
      </div>
    {%- endif -%}

    <h1 class="hero-title animate-fade-up" style="animation-delay:0.2s">
      {{ section.settings.heading }}
    </h1>

    <p class="hero-subtitle animate-fade-up" style="animation-delay:0.3s">
      {{ section.settings.subheading }}
    </p>

    <div class="hero-btns animate-fade-up" style="animation-delay:0.4s">
      <a href="{{ section.settings.btn1_url | default: '/pages/contact' }}" class="btn btn-accent btn-lg">
        {{ section.settings.btn1_text | default: 'Request Quote' }}
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 9h12m-5-5 5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="{{ section.settings.btn2_url | default: '/collections/all' }}" class="btn btn-ghost btn-lg">
        {{ section.settings.btn2_text | default: 'View Products' }}
      </a>
    </div>

    <div class="hero-stats animate-fade-up" style="animation-delay:0.55s">
      {%- for block in section.blocks -%}
        {%- if block.type == 'stat' -%}
          <div class="hero-stat" {{ block.shopify_attributes }}>
            <div class="hero-stat-value">{{ block.settings.value }}</div>
            <div class="hero-stat-label">{{ block.settings.label }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="hero-scroll-hint">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "image_picker", "id": "logo", "label": "Logo (optional, shown inside hero)" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "World-Class Strapping Solutions" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "50+ Years of Manufacturing Excellence in PP Band & PE Tying Tape" },
    { "type": "text", "id": "btn1_text", "label": "Primary button text", "default": "Request Quote" },
    { "type": "url", "id": "btn1_url", "label": "Primary button URL" },
    { "type": "text", "id": "btn2_text", "label": "Secondary button text", "default": "View Products" },
    { "type": "url", "id": "btn2_url", "label": "Secondary button URL" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "50+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Years of Excellence" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "stat", "settings": { "value": "50+", "label": "Years of Excellence" } },
        { "type": "stat", "settings": { "value": "20+", "label": "Countries Served" } },
        { "type": "stat", "settings": { "value": "500+ t/mo", "label": "Production Capacity" } },
        { "type": "stat", "settings": { "value": "#1", "label": "Market Leader in Eggs" } }
      ]
    }
  ]
}
{% endschema %}
