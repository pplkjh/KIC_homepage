<header class="kic-header">
  <div class="kic-container">
    <div class="kic-header__row">
      <a class="kic-logo" href="{{ routes.root_url }}">
        {%- if section.settings.logo != blank -%}
          {{ section.settings.logo | image_url: width: 240 | image_tag: alt: shop.name }}
        {%- else -%}
          <img src="{{ 'kic_logo.png' | asset_url }}" alt="{{ shop.name }}">
        {%- endif -%}
      </a>

      <nav class="kic-nav" aria-label="Primary">
        {%- if section.settings.menu != blank -%}
          {%- for link in section.settings.menu.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        {%- else -%}
          <a href="{{ routes.root_url }}">Home</a>
          <a href="/pages/products">Products</a>
          <a href="/pages/industries">Industries</a>
          <a href="/pages/about">About</a>
          <a href="/pages/contact">Contact</a>
        {%- endif -%}
      </nav>

      <div class="kic-cta">
        {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
          <a class="kic-btn kic-btn--primary" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
        {%- endif -%}
      </div>

      <button class="kic-mobile-toggle" type="button" aria-label="Menu" data-kic-mobile-toggle>
        ☰
      </button>
    </div>
  </div>

  <div class="kic-mobile-menu" data-kic-mobile-menu data-open="false">
    <div class="kic-container" style="padding:12px 0">
      {%- if section.settings.menu != blank -%}
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="{{ routes.root_url }}">Home</a>
        <a href="/pages/products">Products</a>
        <a href="/pages/industries">Industries</a>
        <a href="/pages/about">About</a>
        <a href="/pages/contact">Contact</a>
      {%- endif -%}
      {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
        <a class="kic-btn kic-btn--primary" style="margin-top:10px" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
      {%- endif -%}
    </div>
  </div>
</header>

{% schema %}
{
  "name": "KIC Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "link_list", "id": "menu", "label": "Menu" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Request Quote" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ]
}
{% endschema %}
