<section class="section featured-products" id="products">
  <div class="container">
    <div class="section-header animate-on-scroll">
      {%- if section.settings.badge != blank -%}
        <span class="section-badge">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect width="8" height="8" x="2" y="2" rx="1" stroke="currentColor" stroke-width="1.5"/></svg>
          {{ section.settings.badge }}
        </span>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <!-- Category Filter Tabs -->
    <div class="product-tabs animate-on-scroll">
      <button class="product-tab active" data-filter="all">All Products</button>
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          <button class="product-tab" data-filter="{{ block.settings.id }}" {{ block.shopify_attributes }}>
            {{ block.settings.name }}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Product Grid -->
    <div class="product-grid" id="product-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'product_card' -%}
          <div class="product-card animate-on-scroll" data-category="{{ block.settings.category }}" {{ block.shopify_attributes }}>
            <div class="product-card-img">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_tag: loading: 'lazy', class: 'product-img' }}
              {%- else -%}
                <div class="product-img-placeholder">
                  <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect x="6" y="6" width="36" height="36" rx="4" stroke="currentColor" stroke-width="2" opacity=".3"/><path d="M14 24h20M24 14v20" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity=".3"/></svg>
                </div>
              {%- endif -%}
              <div class="product-card-badge">{{ block.settings.badge | default: block.settings.category }}</div>
            </div>
            <div class="product-card-body">
              <div class="product-card-mono">{{ block.settings.code }}</div>
              <h3 class="product-card-title">{{ block.settings.title }}</h3>
              <p class="product-card-desc">{{ block.settings.description }}</p>
              <div class="product-specs">
                {%- if block.settings.spec1_label != blank -%}
                  <div class="product-spec">
                    <span class="spec-label">{{ block.settings.spec1_label }}</span>
                    <span class="spec-value">{{ block.settings.spec1_value }}</span>
                  </div>
                {%- endif -%}
                {%- if block.settings.spec2_label != blank -%}
                  <div class="product-spec">
                    <span class="spec-label">{{ block.settings.spec2_label }}</span>
                    <span class="spec-value">{{ block.settings.spec2_value }}</span>
                  </div>
                {%- endif -%}
                {%- if block.settings.spec3_label != blank -%}
                  <div class="product-spec">
                    <span class="spec-label">{{ block.settings.spec3_label }}</span>
                    <span class="spec-value">{{ block.settings.spec3_value }}</span>
                  </div>
                {%- endif -%}
              </div>
              <div class="product-card-footer">
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="btn btn-sm btn-outline">
                    View Details
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                {%- endif -%}
                <a href="/pages/contact?product={{ block.settings.title | url_encode }}" class="btn btn-sm btn-primary">Request Quote</a>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_all_link -%}
      <div class="section-cta animate-on-scroll">
        <a href="{{ section.settings.all_url | default: '/collections/all' }}" class="btn btn-outline btn-lg">
          {{ section.settings.all_text | default: 'View All Products' }}
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 9h12m-5-5 5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge text", "default": "Product Catalog" },
    { "type": "text", "id": "title", "label": "Section title", "default": "Premium Strapping Solutions" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle" },
    { "type": "checkbox", "id": "show_all_link", "label": "Show 'View All' button", "default": true },
    { "type": "text", "id": "all_text", "label": "'View All' button text", "default": "View All Products" },
    { "type": "url", "id": "all_url", "label": "'View All' URL" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Tab",
      "settings": [
        { "type": "text", "id": "id", "label": "Category ID (no spaces)", "default": "pp-band" },
        { "type": "text", "id": "name", "label": "Display Name", "default": "PP Band" }
      ]
    },
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Product image" },
        { "type": "select", "id": "category", "label": "Category", "options": [
            {"value":"pp-band","label":"PP Band"},
            {"value":"pe-tape","label":"PE Tying Tape"},
            {"value":"polyester-band","label":"Polyester Band"},
            {"value":"hand-roll","label":"Hand Roll"},
            {"value":"printed-band","label":"Printed Band"},
            {"value":"conductive-band","label":"Conductive Band"}
          ], "default": "pp-band" },
        { "type": "text", "id": "code", "label": "Product code", "default": "PP-1260-BLK" },
        { "type": "text", "id": "badge", "label": "Badge label" },
        { "type": "text", "id": "title", "label": "Product name", "default": "PP Band 12mm × 0.60mm" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "spec1_label", "label": "Spec 1 label", "default": "Width" },
        { "type": "text", "id": "spec1_value", "label": "Spec 1 value", "default": "12mm" },
        { "type": "text", "id": "spec2_label", "label": "Spec 2 label", "default": "Tensile" },
        { "type": "text", "id": "spec2_value", "label": "Spec 2 value", "default": "150kg" },
        { "type": "text", "id": "spec3_label", "label": "Spec 3 label", "default": "Length" },
        { "type": "text", "id": "spec3_value", "label": "Spec 3 value", "default": "2500m" },
        { "type": "url", "id": "link", "label": "Detail page URL" }
      ]
    }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
