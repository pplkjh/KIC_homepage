<section class="section stats-bar" id="about-stats">
  <div class="container">
    <div class="stats-inner animate-on-scroll">
      {%- for block in section.blocks -%}
        {%- if block.type == 'stat' -%}
          <div class="stat-item" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <div class="stat-icon">{{ block.settings.icon }}</div>
            {%- endif -%}
            <div class="stat-value" data-count="{{ block.settings.value_raw }}">{{ block.settings.value }}</div>
            <div class="stat-label">{{ block.settings.label }}</div>
            {%- if block.settings.desc != blank -%}
              <div class="stat-desc">{{ block.settings.desc }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.certs_title != blank -%}
      <div class="certs-row animate-on-scroll">
        <p class="certs-title">{{ section.settings.certs_title }}</p>
        <div class="certs-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'certification' -%}
              <div class="cert-badge" {{ block.shopify_attributes }}>
                <span class="cert-icon">{{ block.settings.icon | default: '🏆' }}</span>
                <span class="cert-name">{{ block.settings.name }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Stats & Certifications",
  "settings": [
    { "type": "text", "id": "certs_title", "label": "Certifications label", "default": "Certifications & Standards" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)" },
        { "type": "text", "id": "value", "label": "Display value (e.g. 50+)", "default": "50+" },
        { "type": "text", "id": "value_raw", "label": "Raw number for counter animation", "default": "50" },
        { "type": "text", "id": "label", "label": "Label", "default": "Years of Excellence" },
        { "type": "text", "id": "desc", "label": "Description (optional)" }
      ]
    },
    {
      "type": "certification",
      "name": "Certification Badge",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🏆" },
        { "type": "text", "id": "name", "label": "Certification name", "default": "ISO 9001" }
      ]
    }
  ],
  "presets": [{
    "name": "Stats & Certifications",
    "blocks": [
      { "type": "stat", "settings": { "icon": "📅", "value": "50+", "value_raw": "50", "label": "Years of Excellence", "desc": "Est. 1973, 3rd generation family business" } },
      { "type": "stat", "settings": { "icon": "🌍", "value": "20+", "value_raw": "20", "label": "Countries Served", "desc": "Global export network" } },
      { "type": "stat", "settings": { "icon": "🏭", "value": "500 t/mo", "value_raw": "500", "label": "Production Capacity" } },
      { "type": "stat", "settings": { "icon": "🤝", "value": "544", "value_raw": "544", "label": "Active Clients" } },
      { "type": "certification", "settings": { "icon": "🏆", "name": "ISO 9001 Certified" } },
      { "type": "certification", "settings": { "icon": "♻️", "name": "RoHS Compliant" } },
      { "type": "certification", "settings": { "icon": "🔵", "name": "Samsung Official Supplier" } }
    ]
  }]
}
{% endschema %}
