<!-- KIC Certifications & Trust Section -->
<section class="kic-certifications section-{{ section.id }}"
  style="background: {{ section.settings.bg_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="kic-section-header kic-section-header--center">
      {%- if section.settings.tagline != blank -%}
        <span class="kic-section-tagline">{{ section.settings.tagline }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="kic-section-title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="kic-section-subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="kic-certs__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'cert' -%}
          <div class="kic-cert-card" {{ block.shopify_attributes }}>
            {%- if block.settings.cert_image != blank -%}
              <div class="kic-cert-card__image-wrap">
                <img src="{{ block.settings.cert_image | image_url: width: 200 }}"
                     alt="{{ block.settings.title | escape }}"
                     class="kic-cert-card__image"
                     loading="lazy"
                     width="200">
              </div>
            {%- else -%}
              <div class="kic-cert-card__icon-wrap">
                <i class="{{ block.settings.icon }}"></i>
              </div>
            {%- endif -%}
            <h4 class="kic-cert-card__title">{{ block.settings.title }}</h4>
            {%- if block.settings.description != blank -%}
              <p class="kic-cert-card__desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Certifications & Trust",
  "tag": "section",
  "class": "kic-section-certifications",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f5f7fa"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Quality Assurance"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Certifications & Standards"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every KIC product undergoes rigorous quality testing. Our certifications prove it."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 80,
      "unit": "px",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 80,
      "unit": "px",
      "label": "Padding bottom"
    }
  ],
  "blocks": [
    {
      "type": "cert",
      "name": "Certification",
      "settings": [
        {
          "type": "image_picker",
          "id": "cert_image",
          "label": "Certification logo/badge image"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Font Awesome icon (if no image)",
          "default": "fas fa-certificate"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Certification title",
          "default": "ISO 9001:2015"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "International quality management standard certified."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Certifications & Trust",
      "category": "KIC Sections",
      "blocks": [
        {
          "type": "cert",
          "settings": {
            "icon": "fas fa-certificate",
            "title": "ISO 9001:2015",
            "description": "Internationally recognized quality management system for consistent product quality."
          }
        },
        {
          "type": "cert",
          "settings": {
            "icon": "fas fa-leaf",
            "title": "RoHS Compliant",
            "description": "Restriction of Hazardous Substances — our materials are free of harmful chemicals."
          }
        },
        {
          "type": "cert",
          "settings": {
            "icon": "fas fa-recycle",
            "title": "100% Recyclable PP",
            "description": "All polypropylene strapping is fully recyclable, supporting circular economy practices."
          }
        },
        {
          "type": "cert",
          "settings": {
            "icon": "fas fa-shield-alt",
            "title": "Korean Virgin Resin",
            "description": "We use premium Korean-grade virgin polypropylene resin for superior strength and fewer machine residues."
          }
        }
      ]
    }
  ]
}
{% endschema %}
