<section class="section industries" id="industries" style="background: var(--muted);">
  <div class="container">
    <div class="section-header animate-on-scroll">
      {%- if section.settings.badge != blank -%}
        <span class="section-badge">{{ section.settings.badge }}</span>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="industries-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'industry' -%}
          <div class="industry-card animate-on-scroll" {{ block.shopify_attributes }}>
            <div class="industry-card-img">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_tag: loading: 'lazy', class: 'industry-img' }}
              {%- else -%}
                <div class="industry-img-placeholder">{{ block.settings.icon | default: '🏭' }}</div>
              {%- endif -%}
              <div class="industry-overlay"></div>
            </div>
            <div class="industry-card-body">
              <div class="industry-icon">{{ block.settings.icon | default: '🏭' }}</div>
              <h3 class="industry-card-title">{{ block.settings.title }}</h3>
              <p class="industry-card-desc">{{ block.settings.description }}</p>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="industry-link">
                  Learn More
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Industries",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "Industries Served" },
    { "type": "text", "id": "title", "label": "Title", "default": "Trusted Across Industries" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Our PP Band and PE Tying Tape solutions are used across 11+ major industries worldwide." }
  ],
  "blocks": [
    {
      "type": "industry",
      "name": "Industry Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "📦" },
        { "type": "text", "id": "title", "label": "Industry name", "default": "Food & Beverage" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "PP strapping secures cartons and pallets in high-speed F&B production lines." },
        { "type": "url", "id": "link", "label": "Link URL" }
      ]
    }
  ],
  "presets": [{
    "name": "Industries",
    "blocks": [
      { "type": "industry", "settings": { "icon": "📦", "title": "Food & Beverage", "description": "PP strapping secures cartons and pallets in high-speed F&B production lines." } },
      { "type": "industry", "settings": { "icon": "🏗️", "title": "Construction & Palletizing", "description": "Heavy-duty PET and PP bands bundle construction materials and secure pallets." } },
      { "type": "industry", "settings": { "icon": "📺", "title": "Electronics", "description": "Conductive and standard PP bands for electronics packaging including Samsung appliances." } },
      { "type": "industry", "settings": { "icon": "🧫", "title": "Clean Room Packaging", "description": "Static-dissipative conductive bands engineered for semiconductor production lines." } },
      { "type": "industry", "settings": { "icon": "🐟", "title": "Agriculture & Fishery", "description": "PE tying tape and PP bands used for seafood, poultry, and agricultural produce." } },
      { "type": "industry", "settings": { "icon": "📰", "title": "Print & Media", "description": "Reliable bundling of newspapers, magazines, and mail in automated dispatch lines." } },
      { "type": "industry", "settings": { "icon": "❄️", "title": "Cold Storage", "description": "Temperature-resistant strapping for cool-store and refrigerated packaging." } },
      { "type": "industry", "settings": { "icon": "👕", "title": "Textile & Garment", "description": "Soft ribbon and PE tape for garment bundling, laundry and apparel packaging." } }
    ]
  }]
}
{% endschema %}
