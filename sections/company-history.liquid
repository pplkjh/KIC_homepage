<!-- KIC Company History / Timeline Section -->
<section class="kic-history section-{{ section.id }}"
  style="background: {{ section.settings.bg_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="kic-section-header kic-section-header--center">
      {%- if section.settings.tagline != blank -%}
        <span class="kic-section-tagline">{{ section.settings.tagline }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="kic-section-title">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="kic-timeline">
      {%- for block in section.blocks -%}
        {%- if block.type == 'milestone' -%}
          <div class="kic-timeline__item {% if forloop.index | modulo: 2 == 0 %}kic-timeline__item--right{% else %}kic-timeline__item--left{% endif %}" {{ block.shopify_attributes }}>
            <div class="kic-timeline__connector">
              <div class="kic-timeline__dot">
                <i class="{{ block.settings.icon }}"></i>
              </div>
            </div>
            <div class="kic-timeline__card">
              <span class="kic-timeline__year">{{ block.settings.year }}</span>
              <h3 class="kic-timeline__title">{{ block.settings.title }}</h3>
              <p class="kic-timeline__desc">{{ block.settings.description }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Company History / Timeline",
  "tag": "section",
  "class": "kic-section-history",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1a3a5c"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "50+ Years of Excellence"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 80,
      "unit": "px",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 80,
      "unit": "px",
      "label": "Padding bottom"
    }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Timeline Milestone",
      "settings": [
        {
          "type": "text",
          "id": "year",
          "label": "Year",
          "default": "1973"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Font Awesome icon",
          "default": "fas fa-flag"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "KIC Founded"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Korea Industrial Company established in Gimpo, Korea, beginning production of polypropylene strapping."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Company History / Timeline",
      "category": "KIC Sections",
      "blocks": [
        {
          "type": "milestone",
          "settings": {
            "year": "1973",
            "icon": "fas fa-flag",
            "title": "KIC Founded",
            "description": "Korea Industrial Company (KIC) was founded by the Shin family in Gimpo, Gyeonggi-do, Korea — beginning production of polypropylene packaging materials."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "year": "1985",
            "icon": "fas fa-industry",
            "title": "Factory Expansion",
            "description": "Significant expansion of manufacturing capacity with the addition of new production lines and equipment, enabling larger-scale domestic supply."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "year": "1995",
            "icon": "fas fa-ship",
            "title": "First International Exports",
            "description": "KIC began exporting PP strapping products internationally, establishing footholds in Japan and Southeast Asian markets."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "year": "2005",
            "icon": "fas fa-certificate",
            "title": "ISO 9001 Certification",
            "description": "KIC achieved ISO 9001 quality management certification, formalizing our commitment to consistent product quality across all product lines."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "year": "2010",
            "icon": "fas fa-globe",
            "title": "Global Expansion to 10+ Countries",
            "description": "KIC's export reach expanded to over 10 countries across Europe, North America, and Oceania — driven by competitive quality and custom OEM offerings."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "year": "2020",
            "icon": "fas fa-users",
            "title": "3rd Generation Takeover",
            "description": "The third generation of the Shin family assumed leadership, bringing digital transformation, new product lines, and a renewed focus on global B2B markets."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "year": "2023",
            "icon": "fas fa-star",
            "title": "50th Anniversary & 20+ Countries",
            "description": "Celebrating 50 years of manufacturing excellence — now exporting to 20+ countries with an expanded product range and state-of-the-art production facilities."
          }
        }
      ]
    }
  ]
}
{% endschema %}
