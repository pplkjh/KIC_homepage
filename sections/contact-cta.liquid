<section class="section contact-cta" id="contact-cta" style="background: var(--primary); color: #fff;">
  <div class="container">
    <div class="cta-inner animate-on-scroll">
      <div class="cta-text">
        <h2 class="cta-title">{{ section.settings.title }}</h2>
        <p class="cta-subtitle">{{ section.settings.subtitle }}</p>
      </div>
      <div class="cta-actions">
        {%- if section.settings.btn1_text != blank -%}
          <a href="{{ section.settings.btn1_url | default: '/pages/contact' }}" class="btn btn-accent btn-lg">
            {{ section.settings.btn1_text }}
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 9h12m-5-5 5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.btn2_text != blank -%}
          <a href="{{ section.settings.btn2_url | default: 'mailto:sales@powerband.co.kr' }}" class="btn btn-outline-white btn-lg">
            {{ section.settings.btn2_text }}
          </a>
        {%- endif -%}
      </div>
      <div class="cta-contact-row">
        {%- if section.settings.phone != blank -%}
          <a href="tel:{{ section.settings.phone }}" class="cta-contact-item">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06L5 9a11 11 0 005 5l.669-1.339a1 1 0 011.06-.54l4.435.74a1 1 0 01.836.986V14a1 1 0 01-1 1h-1C6.82 15 2 10.18 2 4V3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {{ section.settings.phone }}
          </a>
        {%- endif -%}
        {%- if section.settings.email != blank -%}
          <a href="mailto:{{ section.settings.email }}" class="cta-contact-item">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 4a1 1 0 011-1h10a1 1 0 011 1v8a1 1 0 01-1 1H3a1 1 0 01-1-1V4zm0 0l6 5 6-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {{ section.settings.email }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact CTA",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Ready to Get Started?" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Request a free sample or quote today. Our team responds within 24 hours." },
    { "type": "text", "id": "btn1_text", "label": "Primary button", "default": "Request Quote" },
    { "type": "url", "id": "btn1_url", "label": "Primary button URL" },
    { "type": "text", "id": "btn2_text", "label": "Secondary button", "default": "Email Us" },
    { "type": "url", "id": "btn2_url", "label": "Secondary button URL" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "+82-31-998-1740" },
    { "type": "text", "id": "email", "label": "Email", "default": "sales@powerband.co.kr" }
  ],
  "presets": [{ "name": "Contact CTA" }]
}
{% endschema %}
