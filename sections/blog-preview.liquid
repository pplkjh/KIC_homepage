<!-- KIC Blog / News Preview Section -->
<section class="kic-blog-preview section-{{ section.id }}"
  style="background: {{ section.settings.bg_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="kic-section-header kic-section-header--split">
      <div>
        {%- if section.settings.tagline != blank -%}
          <span class="kic-section-tagline">{{ section.settings.tagline }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="kic-section-title">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      <a href="{{ blogs[section.settings.blog].url | default: '/blogs/news' }}" class="btn btn--outline">
        View All Posts <i class="fas fa-arrow-right"></i>
      </a>
    </div>

    <div class="kic-blog-preview__grid">
      {%- assign blog_handle = section.settings.blog | default: 'news' -%}
      {%- assign target_blog = blogs[blog_handle] -%}

      {%- if target_blog != blank and target_blog.articles.size > 0 -%}
        {%- for article in target_blog.articles limit: section.settings.posts_to_show -%}
          <article class="kic-blog-card">
            <div class="kic-blog-card__image-wrap">
              {%- if article.image != blank -%}
                <a href="{{ article.url }}">
                  <img src="{{ article.image | image_url: width: 600 }}"
                       alt="{{ article.image.alt | escape | default: article.title }}"
                       class="kic-blog-card__image"
                       loading="lazy"
                       width="600">
                </a>
              {%- else -%}
                <a href="{{ article.url }}" class="kic-blog-card__no-image">
                  <i class="fas fa-newspaper"></i>
                </a>
              {%- endif -%}
              {%- if article.tags.size > 0 -%}
                <span class="kic-blog-card__tag">{{ article.tags | first }}</span>
              {%- endif -%}
            </div>
            <div class="kic-blog-card__content">
              <div class="kic-blog-card__meta">
                <span><i class="fas fa-calendar-alt"></i> {{ article.published_at | date: '%b %d, %Y' }}</span>
                {%- if article.author != blank -%}
                  <span><i class="fas fa-user"></i> {{ article.author }}</span>
                {%- endif -%}
              </div>
              <h3 class="kic-blog-card__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h3>
              {%- if article.excerpt != blank -%}
                <p class="kic-blog-card__excerpt">{{ article.excerpt | strip_html | truncate: 140 }}</p>
              {%- endif -%}
              <a href="{{ article.url }}" class="kic-blog-card__link">
                Read More <i class="fas fa-arrow-right"></i>
              </a>
            </div>
          </article>
        {%- endfor -%}
      {%- else -%}
        <!-- Placeholder blog posts -->
        {%- assign placeholder_titles = "How to Choose the Right PP Strap Width for Your Application,PP Strapping vs Steel Strapping: A Cost & Performance Comparison,Understanding Breaking Strength in Polypropylene Strapping" | split: "," -%}
        {%- assign placeholder_tags = "Product Guide,Industry Insight,Technical Guide" | split: "," -%}
        {%- assign placeholder_excerpts = "Selecting the correct PP strap width is critical for load security. This guide explains how strap width affects breaking strength, machine compatibility, and total cost of ownership.,Comparing PP strapping to traditional steel banding for industrial packaging — covering cost, sustainability, safety, and performance across key industries.,A technical deep-dive into breaking strength ratings for PP strapping. Learn how to match BS ratings to your load weight and transport conditions." | split: "," -%}
        {%- for i in (0..2) -%}
          <article class="kic-blog-card">
            <div class="kic-blog-card__image-wrap kic-blog-card__image-wrap--placeholder">
              {{ 'image' | placeholder_svg_tag: 'kic-blog-card__svg-placeholder' }}
              <span class="kic-blog-card__tag">{{ placeholder_tags[i] }}</span>
            </div>
            <div class="kic-blog-card__content">
              <div class="kic-blog-card__meta">
                <span><i class="fas fa-calendar-alt"></i> Coming Soon</span>
                <span><i class="fas fa-robot"></i> AI Generated Weekly</span>
              </div>
              <h3 class="kic-blog-card__title">
                <a href="/blogs/news">{{ placeholder_titles[i] }}</a>
              </h3>
              <p class="kic-blog-card__excerpt">{{ placeholder_excerpts[i] }}</p>
              <a href="/blogs/news" class="kic-blog-card__link">
                Read More <i class="fas fa-arrow-right"></i>
              </a>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blog Preview",
  "tag": "section",
  "class": "kic-section-blog-preview",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Knowledge Base"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PP Strapping Industry Insights"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "Number of posts to show"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 80,
      "unit": "px",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 80,
      "unit": "px",
      "label": "Padding bottom"
    }
  ],
  "presets": [
    {
      "name": "Blog Preview",
      "category": "KIC Sections"
    }
  ]
}
{% endschema %}
