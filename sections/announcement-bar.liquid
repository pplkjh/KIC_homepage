{% if section.settings.show_bar %}
<div class="announcement-bar" style="background: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="container">
    <p class="announcement-text">
      {% if section.settings.icon != blank %}{{ section.settings.icon }} {% endif %}
      {{ section.settings.text }}
      {% if section.settings.link != blank %}
        <a href="{{ section.settings.link }}" style="color: inherit; text-decoration: underline; margin-left: 8px;">
          {{ section.settings.link_text }} →
        </a>
      {% endif %}
    </p>
  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    { "type": "checkbox", "id": "show_bar", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "text", "label": "Announcement text", "default": "ISO 9001 Certified · Samsung Electronics Official Supplier · 50+ Years of Manufacturing Excellence" },
    { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🏭" },
    { "type": "text", "id": "link", "label": "Link URL" },
    { "type": "text", "id": "link_text", "label": "Link text", "default": "Learn More" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#1b5e20" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" }
  ]
}
{% endschema %}
