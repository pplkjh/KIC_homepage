<header class="site-header" id="site-header">
  <div class="container">
    <div class="header-inner">

      <!-- Logo -->
      <a href="{{ routes.root_url }}" class="header-logo" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          {{ section.settings.logo | image_tag: width: 120, alt: shop.name, loading: 'eager' }}
        {%- else -%}
          <span class="header-logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <!-- Desktop Nav -->
      <nav class="header-nav" aria-label="Main navigation">
        {%- for link in linklists[section.settings.menu].links -%}
          {%- if link.links != blank -%}
            <div class="nav-item has-dropdown">
              <button class="nav-link" aria-expanded="false" aria-haspopup="true">
                {{ link.title }}
                <svg class="chevron" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <div class="nav-dropdown">
                {%- for child in link.links -%}
                  <a href="{{ child.url }}" class="nav-dropdown-item {% if child.active %}active{% endif %}">{{ child.title }}</a>
                {%- endfor -%}
              </div>
            </div>
          {%- else -%}
            <div class="nav-item">
              <a href="{{ link.url }}" class="nav-link {% if link.active %}active{% endif %}">{{ link.title }}</a>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </nav>

      <!-- Header Actions -->
      <div class="header-actions">

        <!-- Language Switcher -->
        {%- if section.settings.show_language and localization.available_languages.size > 1 -%}
          <div class="lang-picker" id="lang-picker">
            <button class="lang-picker-btn" aria-expanded="false" aria-haspopup="listbox">
              <span>{{ localization.language.iso_code | upcase }}</span>
              <svg class="chevron" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="lang-dropdown" role="listbox">
              {%- form 'localization', id: 'lang-form-desktop', class: 'localization-form' -%}
                {%- for language in localization.available_languages -%}
                  <button type="submit" name="locale_code" value="{{ language.iso_code }}"
                    class="lang-option {% if language.iso_code == localization.language.iso_code %}active{% endif %}"
                    role="option">
                    {{ language.endonym_name }}
                  </button>
                {%- endfor -%}
              {%- endform -%}
            </div>
          </div>
        {%- endif -%}

        <!-- CTA Button -->
        <a href="{{ section.settings.cta_url | default: '/pages/contact' }}" class="btn btn-primary btn-sm">
          {{ section.settings.cta_text | default: 'Request Quote' }}
        </a>

        <!-- Mobile Menu Toggle -->
        <button class="mobile-menu-toggle" id="mobile-menu-toggle" aria-expanded="false" aria-controls="mobile-menu" aria-label="Toggle menu">
          <span class="hamburger-bar"></span>
          <span class="hamburger-bar"></span>
          <span class="hamburger-bar"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav class="mobile-nav">
      {%- for link in linklists[section.settings.menu].links -%}
        {%- if link.links != blank -%}
          <div class="mobile-nav-group">
            <button class="mobile-nav-link mobile-nav-parent" aria-expanded="false">
              {{ link.title }}
              <svg class="chevron" width="14" height="14" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="mobile-nav-children">
              {%- for child in link.links -%}
                <a href="{{ child.url }}" class="mobile-nav-child {% if child.active %}active{% endif %}">{{ child.title }}</a>
              {%- endfor -%}
            </div>
          </div>
        {%- else -%}
          <a href="{{ link.url }}" class="mobile-nav-link {% if link.active %}active{% endif %}">{{ link.title }}</a>
        {%- endif -%}
      {%- endfor -%}

      <div class="mobile-nav-footer">
        {%- if section.settings.show_language and localization.available_languages.size > 1 -%}
          <p class="mobile-lang-label">{{ 'general.language' | t }}</p>
          <div class="mobile-lang-grid">
            {%- form 'localization', id: 'lang-form-mobile', class: 'localization-form' -%}
              {%- for language in localization.available_languages -%}
                <button type="submit" name="locale_code" value="{{ language.iso_code }}"
                  class="mobile-lang-btn {% if language.iso_code == localization.language.iso_code %}active{% endif %}">
                  {{ language.iso_code | upcase }} — {{ language.endonym_name }}
                </button>
              {%- endfor -%}
            {%- endform -%}
          </div>
        {%- endif -%}
        <a href="{{ section.settings.cta_url | default: '/pages/contact' }}" class="btn btn-primary w-full">
          {{ section.settings.cta_text | default: 'Request Quote' }}
        </a>
      </div>
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "link_list", "id": "menu", "label": "Navigation menu", "default": "main-menu" },
    { "type": "checkbox", "id": "show_language", "label": "Show language switcher", "default": true },
    { "type": "text", "id": "cta_text", "label": "CTA button text", "default": "Request Quote" },
    { "type": "url", "id": "cta_url", "label": "CTA button URL" }
  ]
}
{% endschema %}
